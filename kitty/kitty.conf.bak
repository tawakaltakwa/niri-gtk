envinclude KITTY_CONF_*

hide_window_decorations yes
dynamic_background_opacity yes
background_opacity 0.7
background_blur 1
font_size 10

include current-theme.conf



# BEGIN_KITTY_FONTS
font_family      family="NeoSpleen Nerd Font"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS