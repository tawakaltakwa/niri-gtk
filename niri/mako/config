# See man 5 mako

include=~/.config/niri/preset-warna/kuning

max-visible=7
sort=-time
#output=HDMI-A-1
layer=top
anchor=top-right

#font=monospace 10
width=400
height=200
margin=10
padding=5
border-size=2
border-radius=6
icons=1
max-icon-size=64
icon-path=""
markup=1
actions=1
