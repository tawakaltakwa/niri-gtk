{
    // "layer": "top", // Waybar at top layer
    // "position": "top", // Waybar position (top|bottom|left|right)
    "height": 26, // Waybar height (to be removed for auto height)
    "margin-bottom": 1,
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "group/grkiri"
    ],
    "modules-center": [],
    "modules-right": [
        "group/grkanan"
    ],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    },
    "wlr/taskbar": {
        "format": " {icon} ",
        "sort-by-app-id": false,
        "tooltip-format": "{app_id}-{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "niri/workspaces": {
        // "format": "{icon} {index}",
        "format": "{index}",
        "current-only": true,
        "all-outputs": false,
        "expand": true,
        "format-icons": {
            // Named workspaces
            // (you need to configure them in niri)
            //		    "browser": "ţÇç",
            //	    "discord": "´Äĺ",
            //    "chat": "<b>´üÁ</b>",
            // Icons by state
            "active": "´ćĺ",
            "default": "´äĹ"
        }
    },
    "ext/workspaces": {
        "format": " {id} ",
        "on-click": "activate",
        "active-only": true,
        "format-icons": {
            //"Workspace 1": "´äá",
            //"Workspace 2": "´ëĘ",
            //"Workspace 3": "´äí",
            //"Workspace 4": "´ć╝",
            "active": "´ćĺ",
            "default": "´äĹ"
        },
        "sort-by-id": true
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ÔŞĘ{songPosition}|{queueLength}ÔŞę {volume}% ´Çü",
        "format-disconnected": "Disconnected ´Çü",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ´Çü",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "´âä "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">´ü┤</span> ",
            "on": "´ü┤ "
        },
        "repeat-icons": {
            "on": "´Ç× "
        },
        "single-icons": {
            "on": "´Ç×1 "
        },
        "state-icons": {
            "paused": "´üî",
            "playing": "´üő"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "spacing": 2
    },
    "clock": {
        "format": "{:%d %B %Y}",
        "format-alt": "{:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffffff'><b>{}</b></span>",
                "days": "<span color='#ffffff'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff0000'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "CPU: {usage}% ",
        "tooltip": false,
        "on-click": "gnome-system-monitor -r",
        "interval": 10
    },
    "memory": {
        "interval": 30,
        "format": "RAM: {used:0.1f}G/{total:0.1f}G ´âë SWAP: {swapUsed:0.1f}G/{swapTotal:0.1f}G",
        "tooltip": false,
        "on-click": "gnome-system-monitor -p"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [
            "´Łź",
            "´őë",
            "´Łę"
        ]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": [
            "ţÄŹ",
            "ţĆô",
            "ţĆĹ",
            "ţĆĆ",
            "ţĆÄ",
            "ţĆŹ",
            "ţĆŐ",
            "ţĆł",
            "ţÄŤ"
        ]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´Śž",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
        ]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio/slider": {
        "tooltip-format": "Audio Volume",
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        // "format": "{volume}% {icon} {format_source}",
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} ´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon} ´Őö {format_source}",
        "format-muted": "ţ╗Ę  {format_source}",
        "format-source": "{volume}% ´ä░ ",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą ",
            "hands-free": "´ľÉ ",
            "headset": "´ľÉ ",
            "phone": "´éĽ ",
            "portable": "´éĽ ",
            "car": "´ć╣ ",
            "default": [
                "´ÇŽ ",
                "´Çž ",
                "´ÇĘ "
            ]
        },
        "on-click": "pavucontrol -t 1",
        "on-click-right": "kitty -e alsamixer"
    },
    "wireplumber": {
        "format": "{volume}%",
        "format-muted": "´ÇŽ",
        "on-click": "helvum"
    },
    "cffi/niri-taskbar": {
        "module_path": "/usr/lib/waybar/libniri_taskbar.so",
        "show_all_outputs": true,
        "icon-size": 16
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "ÔľÂ",
            "audacious": "ˇ░ôâ",
            "mpv": "­čÄÁ"
        },
        "status-icons": {
            "paused": "ÔĆŞ"
        },
        "max-length": 30,
        "interval": 1
    },
    "custom/power": {
        "format": "´ÇĹ",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "$HOME/.config/niri/waybar/power_menu.xml",
        "menu-actions": {
            "shutdown": "poweroff",
            "reboot": "reboot",
            "logout": "niri msg action quit",
            "lock": "gtklock -s ~/.config/niri/gtklock/style.css"
        }
    },
    "custom/spoweroff": {
        "format": "´ÇĹ",
        "on-click": "poweroff",
        "tooltip-format": "Power Off"
    },
    "custom/spoweroff-dgnkonfirmasi": {
        "format": "ÔĆ╗",
        "tooltip-format": "Power Off / Shutdown",
        "on-click": "~/.config/niri/waybar/popup-konfirmasi-shutdown.py"
    },
    "custom/sreboot-dgnkonfirmasi": {
        "format": "´Ç×",
        "tooltip-format": "Reboot",
        "on-click": "~/.config/niri/waybar/popup-konfirmasi-reboot.py"
    },
    "custom/sreboot": {
        "format": "´Ç×",
        "on-click": "reboot",
        "tooltip-format": "Reboot"
    },
    "custom/ssuspend": {
        "format": "ÔĆż",
        "on-click": "systemctl suspend",
        "tooltip-format": "Suspend"
    },
    "custom/shibernate": {
        "format": "ÔĆ╝",
        "on-click": "systemctl hibernate",
        "tooltip-format": "Hibernate"
    },
    "custom/slock": {
        "format": "´Çú",
        "on-click": "gtklock -s ~/.config/niri/gtklock/style.css",
        "tooltip-format": "Lock"
    },
    "custom/slogout": {
        "format": "´éő",
        "on-click": "niri msg action quit --skip-confirmation",
        "tooltip-format": "Logout"
    },
    "custom/menucommand": {
        "format": "ˇ░Ç╗",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "$HOME/.config/niri/waybar/comm_menu.xml",
        "menu-actions": {
            "ckey": "niri msg action show-hotkey-overlay",
            "crun": "wmenu-run -N 000000 -n ffffff -S ff0000 -s 000000",
            "cterm": "kitty",
            "cbrowser": "firefox",
            "crwaybar": "bash ~/.config/niri/waybar/restart.sh"
        }
    },
    "custom/sc_label": {
        "format": "ˇ░Ç╗",
        "tooltip": false
    },
    "custom/sc_keylist": {
        "format": "´äť",
        "on-click": "niri msg action show-hotkey-overlay",
        "tooltip-format": "Keyboard Shortcut List"
    },
    "custom/sc_terminal": {
        "format": "´äá",
        "on-click": "bash ~/.config/fastfetch/slowfetch.sh",
        "tooltip-format": "Terminal: kitty"
    },
    "custom/sc_run": {
        "format": "ţłŚ",
        "on-click": "wmenu-run -N 000000 -n ffffff -S ff0000 -s 000000",
        "tooltip-format": "Runner: wmenu"
    },
    "custom/sc_filemanager": {
        "format": "ţŚ┐",
        "on-click": "nautilus",
        "tooltip-format": "File Manager: nautilus"
    },
    "custom/sc_configdir": {
        "format": "ţŚ╝",
        "on-click": "./.config/niri/waybar/popup-listconfig.py",
        "tooltip-format": "List Config"
    },
    "custom/sc_browser": {
        "format": "´ëę",
        "on-click": "firefox",
        "tooltip-format": "Browser: Firefox"
    },
    "custom/sc_randwallpaper": {
        "format": "´ÉĆ",
        "on-click": "bash ~/.config/niri/scripts/change-wallpaper.sh",
        "tooltip-format": "Random Wallpaper"
    },
    "custom/sc_rwaybar": {
        "format": "´Çí",
        "on-click": "bash ~/.config/niri/waybar/restart.sh",
        "tooltip-format": "Restart Waybar"
    },
    "custom/launcher": {
        "format": "´îâ",
        "on-click": "wofi -s ~/.config/niri/wofi/styles.css --show drun -I -G -W 40% -l 1",
        "tooltip": false
    },
    "custom/browser": {
        "format": "ţÇç Firefox",
        "on-click": "firefox",
        "tooltip-format": "Browser"
    },
    "custom/spasi": {
        "format": "  ",
        "tooltip": false
    },
    "custom/jamsunda": {
        "format": "{text}",
        "tooltip": false,
        "interval": 60,
        "exec": "bash ~/.config/niri/waybar/jamsunda.sh -f 12 -p",
        "on-click": "bash ~/.config/niri/waybar/jamsunda_info.sh"
    },
    "group/grkanan": {
        "orientation": "horizontal",
        "modules": [
            "group/grwaktu",
            "pulseaudio",
            "group/grsession"
        ]
    },
    "group/grkiri": {
        "orientation": "horizontal",
        "modules": [
            "custom/launcher",
            "group/grshortcut",
            "tray",
            "niri/workspaces",
            "custom/spasi",
            "wlr/taskbar"
        ]
    },
    "group/grtaskbar": {
        "orientation": "horizontal",
        "modules": [
            "ext/workspaces",
            "wlr/taskbar"
        ]
    },
    "custom/labelmon": {
        "format": "´âĄ",
        "tooltip": false,
        "on-click": "gnome-system-monitor"
    },
    "group/grsysmon": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500
        },
        "modules": [
            "custom/labelmon",
            "cpu",
            "memory"
        ]
    },
    "group/grsession": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false
        },
        "modules": [
            "custom/spoweroff-dgnkonfirmasi",
            "custom/slogout",
            "custom/slock",
            // "custom/ssuspend",
            "custom/shibernate",
            "custom/sreboot-dgnkonfirmasi"
        ]
    },
    "group/grshortcut": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "click-to-reveal": true
        },
        "modules": [
            "custom/sc_label",
            "custom/sc_keylist",
            "custom/sc_terminal",
            "custom/sc_run",
            "custom/sc_browser",
            "custom/sc_filemanager",
            "custom/sc_configdir",
            "custom/sc_randwallpaper",
            "custom/sc_rwaybar",
            "group/grgantiwarna"
        ]
    },
    "group/grwaktu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500
        },
        "modules": [
            "custom/jamsunda",
            "clock"
        ]
    },
    "group/grsuara": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio",
            "mpris"
        ]
    },
    "custom/gw-label": {
        "format": "ţźć",
        "tooltip-format": "Ganti Warna"
    },
    "custom/gw-biru": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w biru && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-birumuda": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w birumuda && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-hijau": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w hijau && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-kuning": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w kuning && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-merah": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w merah && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-oren": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w oren && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-pink": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w pink && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "custom/gw-ungu": {
        "format": "ţ¬Ś",
        "tooltip": false,
        "on-click": "bash ~/.config/niri/scripts/ganti-warna.sh -w ungu && bash ~/.config/niri/waybar/restart.sh && makoctl reload"
    },
    "group/grgantiwarna": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500
        },
        "modules": [
            "custom/gw-label",
            "custom/gw-biru",
            "custom/gw-birumuda",
            "custom/gw-hijau",
            "custom/gw-kuning",
            "custom/gw-merah",
            "custom/gw-oren",
            "custom/gw-pink",
            "custom/gw-ungu"
        ]
    }
}